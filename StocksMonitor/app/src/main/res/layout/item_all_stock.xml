<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:background="@drawable/stock_item_border">

    <TextView
        android:id="@+id/stock_token"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Token"
        android:textSize="11sp"
        android:paddingEnd="4dp"
        android:paddingStart="4dp"
        android:gravity="center" />

    <TextView
        android:id="@+id/stock_symbol"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:text="Symbol"
        android:textSize="12sp"
        android:textStyle="bold"
        android:paddingEnd="4dp"
        android:paddingStart="4dp"
        android:gravity="left" />

    <TextView
        android:id="@+id/stock_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:text="Name"
        android:textSize="12sp"
        android:paddingEnd="4dp"
        android:paddingStart="4dp"
        android:gravity="left"
        android:maxLines="2"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/stock_exchange"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8"
        android:text="Exchange"
        android:textSize="11sp"
        android:paddingEnd="4dp"
        android:paddingStart="4dp"
        android:gravity="center" />

    <TextView
        android:id="@+id/stock_segment"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Segment"
        android:textSize="11sp"
        android:paddingEnd="4dp"
        android:paddingStart="4dp"
        android:gravity="center" />

    <TextView
        android:id="@+id/stock_instrument_type"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8"
        android:text="Type"
        android:textSize="11sp"
        android:paddingEnd="4dp"
        android:paddingStart="4dp"
        android:gravity="center" />

    <TextView
        android:id="@+id/stock_lot_size"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.7"
        android:text="Lot"
        android:textSize="11sp"
        android:paddingEnd="4dp"
        android:paddingStart="4dp"
        android:gravity="center" />

</LinearLayout>
