<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@android:color/white">

    <!-- Scroll view for filter options -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Exchange Filter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="4dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Exchange:"
                    android:textStyle="bold"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/exchange_spinner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

            </LinearLayout>

            <!-- Segment Filter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="4dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Segment:"
                    android:textStyle="bold"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/segment_spinner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

            </LinearLayout>

            <!-- Instrument Type Filter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="4dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Type:"
                    android:textStyle="bold"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/instrument_type_spinner"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

            </LinearLayout>

            <!-- Search Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="4dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Search:"
                    android:textStyle="bold"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/search_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Search by symbol or name"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:textSize="12sp"
                    android:padding="4dp" />

            </LinearLayout>

            <!-- Filter Controls Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp"
                android:gravity="center_horizontal">

                <Button
                    android:id="@+id/apply_filters_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Apply Filters"
                    android:layout_marginEnd="4dp"
                    android:textSize="12sp"
                    android:padding="8dp" />

                <Button
                    android:id="@+id/clear_filters_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Clear All"
                    android:layout_marginStart="4dp"
                    android:textSize="12sp"
                    android:padding="8dp" />

            </LinearLayout>

            <!-- Results count -->
            <TextView
                android:id="@+id/results_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total: 0 instruments"
                android:textSize="12sp"
                android:gravity="center"
                android:textStyle="bold"
                android:padding="8dp" />

        </LinearLayout>

    </ScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC" />

    <!-- Table Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#F0F0F0">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:text="Symbol"
            android:textStyle="bold"
            android:textSize="12sp"
            android:paddingEnd="4dp"
            android:paddingStart="4dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Name"
            android:textStyle="bold"
            android:textSize="12sp"
            android:paddingEnd="4dp"
            android:paddingStart="4dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:text="Exchange"
            android:textStyle="bold"
            android:textSize="11sp"
            android:paddingEnd="4dp"
            android:paddingStart="4dp"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Segment"
            android:textStyle="bold"
            android:textSize="11sp"
            android:paddingEnd="4dp"
            android:paddingStart="4dp"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:text="Type"
            android:textStyle="bold"
            android:textSize="11sp"
            android:paddingEnd="4dp"
            android:paddingStart="4dp"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.7"
            android:text="Lot"
            android:textStyle="bold"
            android:textSize="11sp"
            android:paddingEnd="4dp"
            android:paddingStart="4dp"
            android:gravity="center" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC" />

    <!-- Stocks List -->
    <ListView
        android:id="@+id/all_stocks_list_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null" />

    <!-- Empty View -->
    <TextView
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="No stocks found. Try adjusting your filters."
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="gone" />

</LinearLayout>
