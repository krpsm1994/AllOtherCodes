  <!-- Configuration for all Event Listener. -->
  <eventlisteners>
    <!-- The SAP Event Listener to notify MM object changes to the SAP system. -->
    <!-- This listener notifies SAP systems according to the connection IDs 
			configured in the searchconfigs/notificationconfigs below. -->
    <eventlistener>
      <class>com.opentext.sap.damint.service.OTDCEventNotifier</class>
      <!-- Set this to true to activate the Listener -->
      <active>true</active>
      <params>
        <!-- Comma separated list of event IDs to process with this listener -->
        <!-- Event IDs, in EVENT_CTXTS, IS_ENABLED_EXTERNAL=Y :
					10001	Asset Checked-in
					30005	Asset Deleted
					30006	Asset Purged
					30007	User Deleted
					80008	Metadata Updated
					110011	Asset Undeleted
				-->
        <events>10001,30005,30006,30007,80008,110011</events>
      </params>
    </eventlistener>
  </eventlisteners>
