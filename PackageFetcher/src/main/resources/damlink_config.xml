<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<configuration>
  <mediamanager>
    <!-- field id of the Media Manager field used for the SAP status -->
    <statusfieldid>ARTESIA.FIELD.CONTENT</statusfieldid>
    <!-- list of model ids of Media Manager models made available in SAP -->
    <allowedmodels>
      <modelid>ARTESIA.MODEL.DEFAULT</modelid>
    </allowedmodels>
    <!-- update interval in seconds for rereading available field and models in the MediaManager -->
    <updateinterval>60</updateinterval>
    <!-- if true the MediaManager edit properties UI is started upon CRM user 
			clicks on asset content (if he has permissions) otherwise the asset inspector 
			is started. -->
    <editonviewing>false</editonviewing>
    <!-- DAM admin user -->
    <user>tsuper</user>
  </mediamanager>
  <certificates>
    <!-- update interval in seconds for rescan of available SAP certificates -->
    <updateinterval>30</updateinterval>
  </certificates>
  <security>
    <!-- live time in seconds of the security token for WS Basic authentication -->
    <tokenlifetime>1800</tokenlifetime>
    <!-- Number of bits (from left) that are used in the token IP check (For IPv4). -->
    <ipv4tokenmask>32</ipv4tokenmask>
    <!-- Number of bits (from left) that are used in the token IP check (For IPv6). -->
    <ipv6tokenmask>128</ipv6tokenmask>
    <!-- URL encryption key. Normally this is set automatically. -->
    <urlenckey>69b4c14991806be2068f95932287e282</urlenckey>
    <!-- WSDL Basic Authentication Login ID -->
    <wsdllogin/>
    <!-- WSDL Basic Authentication Login Password -->
    <wsdlpass/>
    <encryptionkey/>
  </security>
